# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=llm_reader
DB_PASSWORD=your_strong_password_here
DB_NAME=amazon_reviews

# ── OpenAI (required for AI brief generation only) ────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Pipeline worker (only needed when running the scraper) ────────────────────
# Absolute path to a Chrome profile directory that is logged in to Amazon
CHROME_PROFILE=C:\Users\YourName\chrome-amazon-profile
# Full path to chromedriver binary (leave empty to use PATH)
CHROMEDRIVER_PATH=
# Seconds to pause between page scrapes (increase if getting rate-limited)
SCRAPER_PAUSE=8

# ── Pipeline execution mode ───────────────────────────────────────────────────
# "worker" = poll the DB job queue  |  "direct" = run immediately on trigger
PIPELINE_EXECUTION_MODE=worker
PIPELINE_WORKER_ID=worker-1
PIPELINE_WORKER_POLL_SECONDS=15
PIPELINE_WORKER_HEARTBEAT_SECONDS=30
PIPELINE_WORKER_TIMEOUT_SECONDS=180
